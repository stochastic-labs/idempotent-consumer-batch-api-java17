# .env.example
APP_API_HTTP_ENABLED=true
APP_RABBIT_EXCHANGE=stochastic-exchange
APP_RABBIT_ROUTING_KEY=stochastic-routing-key-input
APP_KAFKA_INPUT_TOPIC=stochastic-input
APP_KAFKA_CONSUMER_ENABLED=true

SERVER_PORT=8082

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

REDIS_HOST=redis
REDIS_PORT=6379

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=stochastic_labs_db
POSTGRES_USERNAME=root
POSTGRES_PASSWORD=root
SPRING_JPA_SHOW_SQL=false

KAFKA_BROKER=kafka:9092

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=conditional-routing-api
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=otlp